{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-template-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "APP_DB",
      "database_name": "cf-template-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
